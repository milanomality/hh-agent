# hh.ru — поиск требует авторизацию приложения: зарегистрируйте приложение
# на https://dev.hh.ru (тип «Личное»), скопируйте Client ID и Client Secret
HH_USER_AGENT=hh-agent/0.1 (ваш-email@example.com)
HH_CLIENT_ID=
HH_CLIENT_SECRET=

# Источник вакансий: auto = hh при заполненных кредах выше, иначе «Работа России»
# (opendata.trudvsem.ru, без регистрации). Можно зафиксировать: hh | trudvsem
VACANCY_SOURCE=auto

# Резюме — локальный файл (plain text / markdown), против него скорятся вакансии
RESUME_PATH=resume.md

# Telegram — токен у @BotFather, свой chat_id можно узнать у @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LLM-провайдер ─────────────────────────────────────────────────────────────
# По умолчанию — БЕСПЛАТНЫЙ тариф Groq: ключ выдаётся бесплатно на
# https://console.groq.com (лимита ~1000 запросов/день хватает с запасом).
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# Альтернативные бесплатные варианты (меняете только BASE_URL / MODEL / KEY):
#   OpenRouter (много бесплатных моделей, суффикс :free — список на openrouter.ai/models):
#     LLM_BASE_URL=https://openrouter.ai/api/v1
#     LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   Gemini (OpenAI-совместимый эндпоинт, ключ в aistudio.google.com):
#     LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#     LLM_MODEL=gemini-2.5-flash
#   Ollama (локально, полностью приватно; ключ — любая непустая строка):
#     LLM_BASE_URL=http://localhost:11434/v1
#     LLM_MODEL=qwen3:8b

# Failover-цепочка: создайте providers.json по образцу providers.json.example —
# тогда агент автоматически переключается между провайдерами при исчерпании лимитов
# (LLM_*-настройки выше в этом случае игнорируются).
LLM_PROVIDERS_FILE=providers.json

# Платный Anthropic — пока не используем. Чтобы включить: LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Поведение
POLL_INTERVAL_MINUTES=20
SCORE_THRESHOLD=7
DB_PATH=hh_agent.db
